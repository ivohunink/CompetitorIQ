generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum CompetitorStatus {
  ACTIVE
  ARCHIVED
}

enum SupportStatus {
  SUPPORTED
  PARTIAL
  NOT_SUPPORTED
  UNKNOWN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DuplicateStatus {
  PENDING
  CONFIRMED
  DISMISSED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          UserRole  @default(VIEWER)
  avatarUrl     String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditLogs     AuditLog[]
  savedFilters  SavedFilter[]
  notificationPrefs NotificationPreference[]
  notifications     Notification[]
  resolvedDuplicates FeatureDuplicate[]
}

model Competitor {
  id            String            @id @default(cuid())
  name          String
  websiteUrl    String?
  logoUrl       String?
  marketSegment String?
  notes         String?
  status        CompetitorStatus  @default(ACTIVE)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  dataSources       DataSource[]
  featureCoverages  FeatureCoverage[]
  scrapeLogs        ScrapeLog[]
  scrapeRuns        ScrapeRun[]
}

model DataSource {
  id            String    @id @default(cuid())
  competitorId  String
  url           String
  type          String    // website, changelog, docs, g2, capterra
  lastScraped   DateTime?
  scrapeEnabled Boolean   @default(true)
  cadence       String    @default("weekly") // daily, weekly
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  competitor    Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
}

model Category {
  id            String    @id @default(cuid())
  name          String    @unique
  description   String?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subcategories Subcategory[]
  features      Feature[]
}

model Subcategory {
  id            String    @id @default(cuid())
  name          String
  categoryId    String
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  category      Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  features      Feature[]

  @@unique([name, categoryId])
}

model Feature {
  id            String    @id @default(cuid())
  name          String
  description   String?
  categoryId    String?
  subcategoryId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory   Subcategory?  @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  coverages             FeatureCoverage[]
  duplicatesAsA         FeatureDuplicate[] @relation("DuplicateA")
  duplicatesAsB         FeatureDuplicate[] @relation("DuplicateB")
  scrapeFeatureResults  ScrapeFeatureResult[]
}

model FeatureCoverage {
  id            String        @id @default(cuid())
  featureId     String
  competitorId  String
  status        SupportStatus @default(UNKNOWN)
  evidenceUrl   String?
  lastVerified  DateTime      @default(now())
  notes         String?
  reviewStatus  ReviewStatus  @default(APPROVED)
  confidence    String?       // HIGH, MEDIUM, LOW (for auto-scraped data)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  feature       Feature       @relation(fields: [featureId], references: [id], onDelete: Cascade)
  competitor    Competitor    @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([featureId, competitorId])
}

model AuditLog {
  id          String    @id @default(cuid())
  userId      String
  action      String    // CREATE, UPDATE, DELETE
  entityType  String    // Competitor, Feature, FeatureCoverage, etc.
  entityId    String
  details     String?   // JSON string of changes
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])
}

model SavedFilter {
  id          String    @id @default(cuid())
  userId      String
  name        String
  filters     String    // JSON string of filter config
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScrapeRun {
  id              String    @id @default(cuid())
  competitorId    String
  competitorName  String
  status          String    // "running", "completed", "failed"
  sourcesScraped  Int       @default(0)
  sourcesFailed   Int       @default(0)
  featuresFound   Int       @default(0)
  newFeatures     Int       @default(0)
  totalDuration   Int?      // milliseconds
  errors          String?   // JSON array of error strings
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  scrapeLogs      ScrapeLog[]
  featureResults  ScrapeFeatureResult[]

  @@index([competitorId])
  @@index([createdAt])
}

model ScrapeLog {
  id              String   @id @default(cuid())
  competitorId    String
  competitorName  String
  sourceUrl       String
  sourceType      String
  status          String   // "success", "failed", "no_content"
  contentLength   Int?
  featuresFound   Int      @default(0)
  newFeatures     Int      @default(0)
  error           String?
  duration        Int?     // milliseconds
  runId           String?
  createdAt       DateTime @default(now())

  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  scrapeRun       ScrapeRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  pageContent     ScrapePageContent?

  @@index([competitorId])
  @@index([createdAt])
  @@index([runId])
}

model ScrapePageContent {
  id            String   @id @default(cuid())
  scrapeLogId   String   @unique
  rawText       String
  createdAt     DateTime @default(now())

  scrapeLog     ScrapeLog @relation(fields: [scrapeLogId], references: [id], onDelete: Cascade)
}

model ScrapeFeatureResult {
  id            String   @id @default(cuid())
  scrapeRunId   String
  featureName   String
  featureId     String?
  isNew         Boolean  @default(false)
  status        String?  // SUPPORTED, PARTIAL, NOT_SUPPORTED
  confidence    String   // HIGH, MEDIUM, LOW
  evidence      String?
  sourceUrl     String?
  sourceType    String?
  createdAt     DateTime @default(now())

  scrapeRun     ScrapeRun @relation(fields: [scrapeRunId], references: [id], onDelete: Cascade)
  feature       Feature?  @relation(fields: [featureId], references: [id], onDelete: SetNull)

  @@index([scrapeRunId])
  @@index([featureId])
}

model NotificationPreference {
  id              String    @id @default(cuid())
  userId          String
  alertType       String    // new_feature, status_change, weekly_digest
  enabled         Boolean   @default(true)
  competitorId    String?   // null = all competitors
  categoryId      String?   // null = all categories
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, alertType])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  type        String    // new_feature, status_change, scrape_complete
  title       String
  message     String
  entityType  String?   // Competitor, Feature, FeatureCoverage
  entityId    String?
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeatureDuplicate {
  id          String          @id @default(cuid())
  featureAId  String
  featureBId  String
  similarity  Float
  method      String          // "string", "ai", "both"
  status      DuplicateStatus @default(PENDING)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime        @default(now())

  featureA    Feature         @relation("DuplicateA", fields: [featureAId], references: [id], onDelete: Cascade)
  featureB    Feature         @relation("DuplicateB", fields: [featureBId], references: [id], onDelete: Cascade)
  resolver    User?           @relation(fields: [resolvedBy], references: [id])

  @@unique([featureAId, featureBId])
}
